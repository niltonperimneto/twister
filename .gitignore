node_modules/
build/
.svelte-kit/
src-tauri/target/
src-tauri/gen/
npm-debug.log*
.DS_Store
*.local
.claude/

# Meson build dir (NOT `build/` — that's the vite output above).
/builddir/

# Subproject checkouts, symlinks, and the resolved-revision lock that meson
# populates from the .wrap files — keep only the .wrap files themselves.
/subprojects/*
!/subprojects/*.wrap
